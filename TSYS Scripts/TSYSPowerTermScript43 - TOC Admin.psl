#
# This script file was recorded automatically.
#
set comm-type telnet
set telnet-port 1023d
set host-name <TSYS_HOST_IP>
ok = [session open]
if {$ok == 0} {return}
wait record
send "tsys<enter>"
wait record
send "<REDACTED_PASSWORD><enter>"
wait record
send "toc admin<tab>"
send "<REDACTED_PASSWORD><enter>"
wait record
send <clear-screen>
wait record
send <clear-screen>
wait record
send "<REDACTED_ID><enter>"
wait record
send <enter>
wait record
